# GlyphX web — environment variables (copy to .env, or set in the deploy host).

# Google Analytics (GA4) measurement ID for the marketing site. Optional.
# When unset, analytics is fully disabled (no script loaded, no events sent).
# Format: G-XXXXXXXXXX
PUBLIC_GA_ID=

# Note: the LaTeX compiler needs no configuration. The engine and its TeX bundle
# are built from crates/tectonic-wasm, staged into static/engine/ by
# `pnpm --filter @glyphx/web sync:engine`, and served from this origin. There is
# no package server to point at any more.
