# Glyph web — environment variables (copy to .env, or set in the deploy host).

# Curated TeX package bundle on a CDN, tried BEFORE the on-demand servers below.
# Card-free durable mirror: publish your captured bundle (apps/web/static/texmirror/)
# to jsDelivr as a GitHub repo or npm package and point this at it. Use a pinned
# version/tag (immutable + instant), not a branch. A miss 404s fast and falls
# through to the servers below. See apps/web/docs/self-host-texlive.md.
# Examples:
#   https://cdn.jsdelivr.net/npm/@glyphx/texmirror@1.0.0/
#   https://cdn.jsdelivr.net/gh/<you>/glyphx-texmirror@v1/
PUBLIC_TEXMIRROR_CDN=

# TeX Live on-demand server the in-browser engine fetches packages from.
# Optional. When set, it's tried FIRST and the app falls back to the public
# TeXlyre server (https://texlive.texlyre.org/) if yours is unreachable.
# Point this at your own (free) Cloudflare-Tunnel server — see
# apps/web/docs/self-host-texlive.md.
PUBLIC_TEXLIVE_ENDPOINT=https://texlive.glyphx.nexonauts.com/

# Google Analytics (GA4) measurement ID for the marketing site. Optional.
# When unset, analytics is fully disabled (no script loaded, no events sent).
# Format: G-XXXXXXXXXX
PUBLIC_GA_ID=
