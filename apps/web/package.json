{
	"name": "@glyphx/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"sync:engine": "node ./scripts/sync-engine.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"lint:eslint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"pretest": "esbuild src/lib/tex/tar.ts src/lib/tex/mount.ts src/lib/citations.ts src/lib/storage/projects.ts src/lib/storage/bridge.ts src/lib/storage/zip.ts src/lib/storage/import.ts --bundle --format=esm --outdir=test/.build --outbase=src/lib --out-extension:.js=.mjs --log-level=error",
		"test": "node --test test/*.test.mjs"
	},
	"dependencies": {
		"@glyphx/tex-engine": "workspace:*",
		"@glyphx/ui": "workspace:*",
		"@tabler/icons-svelte": "^3.44.0",
		"clsx": "^2.1.1",
		"gsap": "^3.15.0",
		"pdfjs-dist": "6.0.227",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/gsap": "^3.0.0",
		"@types/node": "^25",
		"esbuild": "^0.28.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"wrangler": "^4.42.0"
	}
}
