{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "GlyphTeX",
	"version": "0.1.0",
	"identifier": "com.nexonauts.glyphtex",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "pnpm run ui:dev",
		"beforeBuildCommand": "pnpm run ui:build"
	},
	"app": {
		"windows": [
			{
				"title": "GlyphTeX",
				"width": 1280,
				"height": 832,
				"minWidth": 880,
				"minHeight": 600,
				"center": true,
				"resizable": true,
				"fullscreen": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"publisher": "Nexonauts",
		"externalBin": ["binaries/tectonic"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"fileAssociations": [
			{
				"ext": ["tex"],
				"name": "LaTeX Document",
				"description": "LaTeX source document",
				"role": "Editor",
				"mimeType": "text/x-tex"
			},
			{
				"ext": ["glyphtex"],
				"name": "GlyphTeX Project",
				"description": "GlyphTeX LaTeX project",
				"role": "Editor",
				"mimeType": "application/x-glyphtex-project"
			}
		],
		"windows": {
			"digestAlgorithm": "sha256",
			"timestampUrl": "http://timestamp.digicert.com"
		},
		"macOS": {
			"minimumSystemVersion": "10.15"
		},
		"linux": {
			"appimage": {}
		},
		"createUpdaterArtifacts": true,
		"android": {
			"debugApplicationIdSuffix": ".debug"
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhBMDUyMzE0NDAwMUVGN0QKUldSOTd3RkFGQ01GaXEydXZqMmpTTHYzV1Nnc2E4ei9PZXdUN3BRK1VVRlZHRWNqQW1pWHJVd2sK",
			"endpoints": ["https://github.com/kanakkholwal/glyphtex/releases/latest/download/latest.json"],
			"dialog": false
		}
	}
}
