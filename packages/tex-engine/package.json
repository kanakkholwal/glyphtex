{
	"name": "glyphtex-engine",
	"version": "0.1.0",
	"description": "Typed TypeScript bindings for the GlyphTeX TeX engine (Tectonic compiled to WebAssembly)",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kanakkholwal/glyphtex.git",
		"directory": "packages/tex-engine"
	},
	"homepage": "https://github.com/kanakkholwal/glyphtex/tree/main/packages/tex-engine#readme",
	"bugs": "https://github.com/kanakkholwal/glyphtex/issues",
	"files": ["dist", "src", "wasm"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./wasm": "./wasm/tectonic_wasm.wasm",
		"./bundle": "./wasm/tectonic-bundle.tar.gz",
		"./packs/index.json": "./wasm/packs/packs-index.json",
		"./packs/*": "./wasm/packs/*",
		"./package.json": "./package.json"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"generate": "node ./scripts/generate-types.mjs",
		"sync:wasm": "node ./scripts/sync-wasm.mjs",
		"refresh": "node ./scripts/refresh-engine.mjs",
		"bundle": "node ./scripts/rebuild-bundle.mjs",
		"bundle:verify": "node ./scripts/verify-bundle.mjs",
		"bundle:format": "node ./scripts/make-format.mjs",
		"bundle:build": "node ./scripts/build-bundle.mjs",
		"bundle:pack": "node ./scripts/pack-bundle.mjs",
		"bundle:packs": "node ./scripts/build-packs.mjs",
		"build": "tsc -p tsconfig.json",
		"check": "tsc -p tsconfig.json --noEmit",
		"test": "node --test test/*.test.mjs",
		"release:prepare": "pnpm build && pnpm sync:wasm && node ./scripts/preflight.mjs",
		"prepublishOnly": "pnpm release:prepare"
	},
	"devDependencies": {
		"typescript": "^5.9.3"
	}
}
